#!/usr/bin/env bash
set -e

REPO="$(cd "$(dirname "$0")/.." && pwd)"
GOAL="$REPO/../goal"

# Upgrade Go-level dependency
go get -u codeberg.org/anaseto/goal
go mod tidy

echo "Pulling goal repo..."
git -C "$GOAL" pull --rebase --prune

GOALSHA="$(git -C "$GOAL" rev-parse HEAD)"
echo "Goal HEAD: $GOALSHA"

echo "Syncing Goal standard library files into libs/ from $GOAL/lib ..."
# Remove any previously-vendored Goal .goal files from libs/ by name before
# re-copying. This handles upstream renames and deletions cleanly without
# touching ari's own files in the same directory.
find "$GOAL/lib" -type f -name '*.goal' | while read -r src; do
    rm -f "$REPO/libs/$(basename "$src")"
done
find "$GOAL/lib" -type f -name '*.goal' | xargs -I {} cp {} "$REPO/libs/"

echo "Done. libs/ updated with Goal standard library files (commit $GOALSHA)."
