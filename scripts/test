#!/usr/bin/env bash
# Run the ari test suite.
# Must be run from the repository root, or via: scripts/test

set -e
cd "$(dirname "$0")/.."

# Go package tests (sql, http, …)
go test -v -failfast -race -covermode=atomic -coverprofile=coverage.txt -coverpkg=./... ./sql/... ./http/...

# Goal-level tests
# GOALLIB makes lib/ available to plain `import "name"` calls in Goal files,
# so test files can declare their own deps without being pre-loaded here.
export GOALLIB="$(pwd)/lib"
go run ./cmd/ari goal run-tests.goal
