file::0n;rule:"/"+79*"=";parse:{[file]file;raw: 'read file;rule\raw}
render:{[step](text;code):rx#\n\)\n#\step;say "$rule\n$text";lines:=code;lines:lines[&~""~'lines]; {print "$x\n";res: 'eval x; print " $res\n"}'lines;say"";say rq^(run next"" to proceed)^}
idx::1;steps::();next:{?[idx=-1+#steps;[ 'eval *steps;say "$rule\nFinished lab '${main.labtitle}' (by ${main.labauthor})"];[idx::idx+1;render steps[idx]]]}
play:{[parts]\pre:*parts;steps::parts; 'eval pre;say rule;say "Lab: '${main.labtitle}' (by ${main.labauthor})";render steps[idx]}
start:{[file]file::file;parts:parse file;play parts}
1
