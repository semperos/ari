#!/usr/bin/env ruby
# scripts/smoke-test-examples — Run each example and verify it exits cleanly.
#
# Strategy: examples are non-interactive scripts that run to completion.
# A process that exits with status 0 → passed.
# A process that exits with a non-zero status, or exceeds TIMEOUT_SECS → failed.
#
# Usage:
#   scripts/smoke-test-examples            # build ari first, then test
#   scripts/smoke-test-examples --no-build # skip build, use existing binary

require "tempfile"
require "optparse"

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
TIMEOUT_SECS  = 30
POLL_INTERVAL = 0.1

ROOT = File.expand_path("..", __dir__)
Dir.chdir(ROOT)

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
build = true
OptionParser.new do |opts|
  opts.on("--no-build", "Skip building ari; use existing binary") { build = false }
end.parse!

ari = ENV.fetch("ARI", "./ari")

# ---------------------------------------------------------------------------
# Colour helpers
# ---------------------------------------------------------------------------
def green(s)  = "\e[0;32m#{s}\e[0m"
def red(s)    = "\e[0;31m#{s}\e[0m"
def yellow(s) = "\e[1;33m#{s}\e[0m"

# ---------------------------------------------------------------------------
# Build
# ---------------------------------------------------------------------------
if build
  system("./scripts/build") or abort("Build failed.")
  puts "Built: #{ari}\n\n"
end

unless File.executable?(ari)
  abort "Error: '#{ari}' not found or not executable.\n" \
        "Run without --no-build, or set ARI=/path/to/ari."
end

# ---------------------------------------------------------------------------
# Smoke-test loop
# ---------------------------------------------------------------------------
examples = Dir["examples/*.goal"].sort

abort "No examples found in examples/" if examples.empty?

puts "Smoke-testing #{examples.size} example(s) (timeout: #{TIMEOUT_SECS}s each)..."
puts

passed = []
failed = []

examples.each do |example|
  name = File.basename(example)
  log  = Tempfile.new(["ari-smoke-#{File.basename(name, '.goal')}-", ".log"])

  pid = spawn(ari, example, out: log, err: log)

  # Poll until the process exits or the timeout expires.
  deadline = Time.now + TIMEOUT_SECS
  exit_status = nil
  while Time.now < deadline
    sleep POLL_INTERVAL
    result = Process.waitpid2(pid, Process::WNOHANG) rescue nil
    if result
      exit_status = result[1].exitstatus.to_i
      break
    end
  end

  if exit_status.nil?
    # Timed out — kill and record as failure.
    Process.kill("TERM", pid) rescue nil
    Process.wait(pid)         rescue nil
    puts "  #{red("FAIL")}  #{name}  (timed out after #{TIMEOUT_SECS}s)"
    log.rewind
    log.read.each_line { |l| print "    #{l}" }
    failed << name
  elsif exit_status == 0
    puts "  #{green("PASS")}  #{name}"
    passed << name
  else
    puts "  #{red("FAIL")}  #{name}  (exited #{exit_status})"
    puts "    #{yellow("--- captured output ---")}"
    log.rewind
    log.read.each_line { |l| print "    #{l}" }
    puts "    #{yellow("-----------------------")}"
    failed << name
  end

  log.close!
end

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
puts
puts "Results: #{passed.size} passed, #{failed.size} failed"

if failed.any?
  puts red("Failed examples:")
  failed.each { |n| puts "  - #{n}" }
  exit 1
end

puts green("All examples ran successfully.")
